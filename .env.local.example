# Local-only env. Copy to `.env.local` and adjust as needed.
# .env.local is git-ignored.

# Tells @google-cloud/firestore to talk to the local emulator instead of Google Cloud.
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# Any non-empty string works for the emulator. Real prod uses the GCP-injected env.
GOOGLE_CLOUD_PROJECT=demo-trip
